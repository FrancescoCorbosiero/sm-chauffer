# Copy to `.env` and fill in. The site runs fine with all of these blank —
# the booking/contact forms then fall back to the WhatsApp / mailto handoff.

# Google Search Console verification token (the content of the
# <meta name="google-site-verification"> tag). Leave blank if unused.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- AWS SES email routing (the "WP Mail SMTP via SES" equivalent) -----------
# When all of AWS_REGION + SES_FROM_EMAIL + SES_TO_EMAIL are set, the /api/quote
# route sends booking/contact submissions through SES. Credentials are read
# from the standard AWS chain (the two AWS_* keys below, an instance role, etc.).
#
# Setup: verify SES_FROM_EMAIL (or its domain) as a sending identity in SES, and
# request production access to leave the SES sandbox (sandbox can only send to
# verified recipients). SES_TO_EMAIL can be any address (e.g. an external Gmail).
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=
SES_TO_EMAIL=
